{
  "manifest_version": 3,
  "name": "Ghost Pop Crosslister",
  "version": "0.1.0",
  "description": "Draft one resale listing and queue cross-listing jobs for Depop, Vinted, Poshmark, and eBay.",
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://www.depop.com/*",
    "https://www.vinted.com/*",
    "https://poshmark.com/*",
    "https://www.ebay.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.depop.com/*"],
      "js": ["content/depop.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.vinted.com/*"],
      "js": ["content/vinted.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://poshmark.com/*"],
      "js": ["content/poshmark.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ebay.com/*"],
      "js": ["content/ebay.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Ghost Pop Crosslister",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
